{
    "_comment": "Agent Console shell config — mobile-app style: an always-on top toolbar with a left brand + right-aligned actions (language, theme, user avatar); per-node connection status is a coloured glyph on each node tab, not a global dot. Primary nav (Console / Nodes / Stats) is the left rail on desktop and the bottom icon-bar on mobile; submenus render as top tabs. The toolbar user avatar shows the logged-in user's initials and navigates to /settings/auth (login form when signed out). TreeDB lives in the separate gui_treedb SPA.",

    "shell": {
        "breakpoints": "bulma",

        "zones": {
            "top":     { "host": "toolbar",        "show_on": "*" },
            "left":    { "host": "menu.primary",   "show_on": ">=desktop" },
            "bottom":  { "host": "menu.primary",   "show_on": "<desktop"  },
            "top-sub": { "host": "menu.secondary", "show_on": "*" },
            "center":  { "host": "stage.main" }
        },

        "stages": {
            "main": { "zone": "center", "default_route": "/commands/nodes" }
        },

        "_routes_comment": "Resolution-ancestor + empty-state routes for the per-node workspaces (a node tab /<ws>/node/<id> resolves here on F5 before the controller rebuilds it). Settings pages are declared as submenu targets under the Settings primary item, not here.",
        "routes": {
            "/commands/node": {
                "stage": "main",
                "gclass": "C_AGENT_CONSOLE",
                "kw": { "title": "commands", "node": "" },
                "lifecycle": "keep_alive"
            },
            "/statistics/node": {
                "stage": "main",
                "gclass": "C_AGENT_STATS",
                "kw": { "title": "statistics", "node": "" },
                "lifecycle": "keep_alive"
            },
            "/terminal/node": {
                "stage": "main",
                "gclass": "C_AGENT_TTY",
                "kw": { "title": "terminal", "node": "" },
                "lifecycle": "keep_alive"
            }
        }
    },

    "toolbar": {
        "zone": "top",
        "aria_label": "Agent Console toolbar",
        "items": [
            {
                "id": "brand",
                "type": "brand",
                "logo": "/agent-mark.svg",
                "wordmark": "Agent Console",
                "alt": "Agent Console",
                "aria_label": "Agent Console home",
                "action": { "type": "navigate", "route": "/commands/nodes" }
            },
            {
                "id": "lang",
                "icon": "yi-language",
                "name": "ES/EN",
                "align": "end",
                "aria_label": "Toggle language",
                "action": { "type": "event", "event": "EV_TOGGLE_LANGUAGE" }
            },
            {
                "id": "theme",
                "icon": "yi-moon",
                "name": "",
                "align": "end",
                "aria_label": "Toggle dark theme",
                "action": { "type": "event", "event": "EV_TOGGLE_THEME" }
            },
            {
                "id": "user",
                "type": "avatar",
                "align": "end",
                "aria_label": "Account menu",
                "action": {
                    "type": "dropdown",
                    "_items_comment": "Account menu is trimmed: Preferences + About are now the Settings primary item (rail). Only the developer-window toggle and Sign out remain here.",
                    "items": [
                        {
                            "id": "settings",
                            "name": "settings",
                            "icon": "yi-gear",
                            "action": { "type": "navigate", "route": "/settings/preference" }
                        },
                        {
                            "id": "developer",
                            "name": "developer",
                            "icon": "yi-square-js",
                            "action": { "type": "event", "event": "EV_OPEN_DEVTOOLS" }
                        },
                        { "type": "divider" },
                        {
                            "id": "logout",
                            "name": "logout",
                            "icon": "yi-sign-out-alt",
                            "action": { "type": "event", "event": "EV_LOGOUT" }
                        }
                    ]
                }
            }
        ]
    },

    "menu": {
        "primary": {
            "render": {
                "left":   { "layout": "vertical", "icon_pos": "left", "show_label": true },
                "bottom": { "layout": "icon-bar", "icon_pos": "top",  "show_label": true }
            },
            "_items_comment": "Four primary options. The three per-node workspaces (Commands, Statistics, Terminal) each declare ONLY their fixed node-picker tab here; the C_APP workspaces controller replaces the submenu at runtime, keeping this picker as tab 0 and appending one closable tab per selected node. Commands/Statistics list only agents >= 7.7.0 (min_version); Terminal (PTY backdoor) lists every version.",
            "items": [
                {
                    "id": "commands",
                    "name": "commands",
                    "icon": "yi-terminal",
                    "tooltip": "Run control-plane commands on a node's yunos (agent >= 7.7.0)",
                    "route": "/commands",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "picker",
                                "name": "nodes",
                                "icon": "yi-cloudversify",
                                "route": "/commands/nodes",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_NODES",
                                    "kw": { "title": "nodes", "workspace": "commands", "min_version": "7.7.0" },
                                    "lifecycle": "keep_alive"
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "statistics",
                    "name": "statistics",
                    "icon": "yi-eye",
                    "tooltip": "Live stats from a node's yunos (agent >= 7.7.0)",
                    "route": "/statistics",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "picker",
                                "name": "nodes",
                                "icon": "yi-cloudversify",
                                "route": "/statistics/nodes",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_NODES",
                                    "kw": { "title": "nodes", "workspace": "statistics", "min_version": "7.7.0" },
                                    "lifecycle": "keep_alive"
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "terminal",
                    "name": "terminal",
                    "icon": "yi-lock",
                    "tooltip": "Interactive SSH-style console to a node (PTY backdoor, any version)",
                    "route": "/terminal",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "picker",
                                "name": "nodes",
                                "icon": "yi-cloudversify",
                                "route": "/terminal/nodes",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_NODES",
                                    "kw": { "title": "nodes", "workspace": "terminal", "min_version": "" },
                                    "lifecycle": "keep_alive"
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "settings",
                    "name": "settings",
                    "icon": "yi-gear",
                    "tooltip": "Application settings",
                    "route": "/settings",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "preference",
                                "name": "preferences",
                                "icon": "yi-gear",
                                "route": "/settings/preference",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_ACCOUNT_VIEW",
                                    "kw": { "view": "preference" },
                                    "lifecycle": "lazy_destroy"
                                }
                            },
                            {
                                "id": "about",
                                "name": "about",
                                "icon": "yi-question",
                                "route": "/settings/about",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_ACCOUNT_VIEW",
                                    "kw": { "view": "about" },
                                    "lifecycle": "lazy_destroy"
                                }
                            }
                        ]
                    }
                }
            ]
        }
    }
}
